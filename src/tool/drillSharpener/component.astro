---
import type { DrillSharpenerUI } from "./ui";
interface Props {
  ui?: DrillSharpenerUI;
}
const { ui } = Astro.props;
const t = (ui ?? {}) as DrillSharpenerUI;
---

<div class="drillsharp-root" id="drill-app">
  <div class="drillsharp-layout">
    <section class="drillsharp-gauge">
      <svg class="drillsharp-svg" viewBox="0 0 500 500" id="gauge-svg">
        <line
          x1="250"
          y1="20"
          x2="250"
          y2="480"
          stroke="currentColor"
          stroke-width="2"
          stroke-dasharray="10,10"></line>
        <line
          x1="20"
          y1="250"
          x2="480"
          y2="250"
          stroke="currentColor"
          stroke-width="1"
          stroke-dasharray="10,10"></line>
        <rect x="249" y="250" width="2" height="230" fill="currentColor" rx="1"
        ></rect>
        <g
          class="drillsharp-guide-circles"
          fill="none"
          stroke="currentColor"
          stroke-width="1"
        >
          <circle cx="250" cy="250" r="30" data-val="3"></circle>
          <circle cx="250" cy="250" r="60" data-val="6"></circle>
          <circle cx="250" cy="250" r="100" data-val="10"></circle>
          <circle cx="250" cy="250" r="130" data-val="13"></circle>
          <circle cx="250" cy="250" r="200" data-val="20"></circle>
        </g>
        <g id="drillsharp-gauge-lines" class="drillsharp-gauge-lines">
          <line
            id="gl"
            x1="250"
            y1="250"
            x2="50"
            y2="100"
            stroke="var(--drillsharp-accent)"
            stroke-width="3"
            stroke-linecap="round"></line>
          <line
            id="gr"
            x1="250"
            y1="250"
            x2="450"
            y2="100"
            stroke="var(--drillsharp-accent)"
            stroke-width="3"
            stroke-linecap="round"></line>
          <circle cx="250" cy="250" r="6" fill="var(--drillsharp-accent)"></circle>
        </g>
        <text
          id="drillsharp-angle-text"
          x="250"
          y="235"
          text-anchor="middle"
          fill="var(--drillsharp-accent)"
          font-size="28"
          font-weight="900">118°</text
        >
      </svg>
      <div class="drillsharp-instruction">
        <span>{t.gaugeInstruction}</span>
      </div>
    </section>

    <aside class="drillsharp-controls">
      <div class="drillsharp-group">
        <h4>{t.labelMaterial}</h4>
        <div class="drillsharp-material-grid">
          <button
            class="drillsharp-mat-btn active"
            data-angle="118"
            data-vc="25"
            data-label="Acero / Hierro"
            data-id="steel">{t.matSteel}</button
          >
          <button
            class="drillsharp-mat-btn"
            data-angle="135"
            data-vc="12"
            data-label="Inoxidable"
            data-id="inox">{t.matInox}</button
          >
          <button
            class="drillsharp-mat-btn"
            data-angle="140"
            data-vc="8"
            data-label="Aceros Duros"
            data-id="hard">{t.matHard}</button
          >
          <button
            class="drillsharp-mat-btn"
            data-angle="90"
            data-vc="40"
            data-label="Latón / Cobre"
            data-id="brass">{t.matBrass}</button
          >
          <button
            class="drillsharp-mat-btn"
            data-angle="60"
            data-vc="60"
            data-label="Plásticos"
            data-id="plastic">{t.matPlastic}</button
          >
          <button
            class="drillsharp-mat-btn"
            data-angle="80"
            data-vc="35"
            data-label="Madera"
            data-id="wood">{t.matWood}</button
          >
        </div>
      </div>

      <div class="drillsharp-group">
        <h4>{t.labelDiameter}</h4>
        <div class="drillsharp-stepper">
          <button type="button" class="drillsharp-step-btn" id="btn-minus">−</button>
          <input
            type="number"
            id="diam-input"
            value="10"
            step="0.5"
            min="1"
            max="50"
          />
          <button type="button" class="drillsharp-step-btn" id="btn-plus">+</button>
        </div>

        <div class="drillsharp-results">
          <div class="drillsharp-res-item">
            <span class="drillsharp-res-label">{t.labelVelocity}</span>
            <div class="drillsharp-res-value-box">
              <span class="drillsharp-res-value" id="rpm-display">796</span>
              <span class="drillsharp-res-unit">{t.unitRpm}</span>
            </div>
          </div>
          <div class="drillsharp-res-item">
            <span class="drillsharp-res-label">{t.labelCooling}</span>
            <div class="drillsharp-res-value-box">
              <span
                class="drillsharp-res-value"
                id="cooling-display"
                style="font-size: 0.8rem; color: var(--drillsharp-accent);"
                >TALADRINA</span
              >
            </div>
          </div>
        </div>
      </div>

      <button
        class="drillsharp-diag-btn"
        id="trigger-diag"
        title="Si la broca no corta, pulsa aquí"
      >
        {t.btnDiagnosis}
      </button>
    </aside>
  </div>

  <div class="drillsharp-modal" id="diag-modal">
    <div class="drillsharp-modal-header">
      <h3>{t.diagTitle}</h3>
      <button type="button" class="drillsharp-modal-close" id="close-modal">×</button>
    </div>

    <div class="drillsharp-diag-item">
      <strong>{t.diagIssue1}</strong>
      <p>{t.diagIssue1Desc}</p>
      <div class="drillsharp-diag-img">
        <svg viewBox="0 0 160 60" width="100%">
          <path
            d="M10,45 L40,15 L70,45 Z"
            fill="none"
            stroke="#ef4444"
            stroke-width="2"></path>
          <line
            x1="40"
            y1="15"
            x2="70"
            y2="15"
            stroke="#ef444430"
            stroke-width="1"
            stroke-dasharray="3,3"></line>
          <path
            d="M90,45 L120,15 L150,25 L150,45 Z"
            fill="none"
            stroke="#22c55e"
            stroke-width="2"></path>
          <line
            x1="120"
            y1="15"
            x2="150"
            y2="15"
            stroke="#22c55e30"
            stroke-width="1"
            stroke-dasharray="3,3"></line>
          <text x="10" y="58" fill="#ef4444" font-size="7">MAL: Plano</text>
          <text x="90" y="58" fill="#22c55e" font-size="7">OK: Destalonado</text
          >
        </svg>
      </div>
    </div>

    <div class="drillsharp-diag-item">
      <strong>{t.diagIssue2}</strong>
      <p>{t.diagIssue2Desc}</p>
    </div>

    <div class="drillsharp-diag-item">
      <strong>{t.diagIssue3}</strong>
      <p>{t.diagIssue3Desc}</p>
    </div>
  </div>
</div>

<script>
  import { calculateSharpener } from "./engine";

  const state = { angle: 118, vc: 25, diameter: 10, materialId: "steel" };

  const ui = {
    gaugeL: document.getElementById("gl") as SVGLineElement,
    gaugeR: document.getElementById("gr") as SVGLineElement,
    angleText: document.getElementById("drillsharp-angle-text") as SVGTextElement,
    rpmDisplay: document.getElementById("rpm-display") as HTMLElement,
    coolingDisplay: document.getElementById("cooling-display") as HTMLElement,
    diamInput: document.getElementById("diam-input") as HTMLInputElement,
    btnMinus: document.getElementById("btn-minus") as HTMLElement,
    btnPlus: document.getElementById("btn-plus") as HTMLElement,
    diagTrigger: document.getElementById("trigger-diag") as HTMLElement,
    modal: document.getElementById("diag-modal") as HTMLElement,
    modalClose: document.getElementById("close-modal") as HTMLElement,
  };

  function updateGauge() {
    if (!ui.gaugeL || !ui.gaugeR) return;
    const halfRad = (state.angle / 2) * (Math.PI / 180);
    const len = 250;
    const lx2 = 250 - Math.sin(halfRad) * len;
    const ly2 = 250 + Math.cos(halfRad) * len;
    const rx2 = 250 + Math.sin(halfRad) * len;
    const ry2 = 250 + Math.cos(halfRad) * len;

    ui.gaugeL.setAttribute("x2", lx2.toString());
    ui.gaugeL.setAttribute("y2", ly2.toString());
    ui.gaugeR.setAttribute("x2", rx2.toString());
    ui.gaugeR.setAttribute("y2", ry2.toString());
    if (ui.angleText) ui.angleText.textContent = `${state.angle}°`;
  }

  function updateResults() {
    const result = calculateSharpener(state.materialId, state.diameter);
    if (ui.rpmDisplay) ui.rpmDisplay.textContent = result.rpm.toLocaleString();
    if (ui.coolingDisplay) ui.coolingDisplay.textContent = result.cooling;
  }

  function refresh() {
    updateGauge();
    updateResults();
  }

  document.querySelectorAll(".drillsharp-mat-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      document
        .querySelectorAll(".drillsharp-mat-btn")
        .forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      state.angle = parseInt(btn.getAttribute("data-angle") || "118");
      state.vc = parseInt(btn.getAttribute("data-vc") || "25");
      state.materialId = btn.getAttribute("data-id") || "steel";
      refresh();
    });
  });

  ui.diamInput?.addEventListener("input", () => {
    state.diameter = parseFloat(ui.diamInput.value) || 1;
    refresh();
  });

  ui.btnMinus?.addEventListener("click", () => {
    const v = Math.max(1, parseFloat(ui.diamInput.value) - 0.5);
    ui.diamInput.value = v.toString();
    state.diameter = v;
    refresh();
  });

  ui.btnPlus?.addEventListener("click", () => {
    const v = Math.min(50, parseFloat(ui.diamInput.value) + 0.5);
    ui.diamInput.value = v.toString();
    state.diameter = v;
    refresh();
  });

  ui.diagTrigger?.addEventListener("click", () =>
    ui.modal?.classList.add("active"),
  );
  ui.modalClose?.addEventListener("click", () =>
    ui.modal?.classList.remove("active"),
  );

  refresh();
</script>

