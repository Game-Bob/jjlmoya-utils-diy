---
import { Icon } from 'astro-icon/components';
import type { CutOptimizerUI } from './ui';

interface Props {
  ui?: Record<string, unknown>;
}
const { ui } = Astro.props;
const t = (ui ?? {}) as CutOptimizerUI;
---

<div
  class="co-root"
  data-co-root
  data-co-stock-label={t.stockLabel}
  data-co-panel-label={t.panelLabel}
  data-co-waste-label={t.wasteLabel}
  data-co-eff-label={t.effLabel}
  data-co-empty={t.emptyState}
  data-co-no-cuts={t.noValidCuts}
  data-co-no-panels={t.noValidPanels}
>
  <div class="co-grid">

    <div class="co-sidebar">
      <div class="co-card">
        <h3 class="co-card-title">
          <Icon name="mdi:cog" />
          {t.configTitle}
        </h3>

        <div class="co-mode-toggle">
          <button class="co-mode-btn" data-co-mode-btn="linear">{t.modeLinearLabel}</button>
          <button class="co-mode-btn" data-co-mode-btn="panel">{t.modePanelLabel}</button>
        </div>

        <div class="co-fields">
          <div class="co-field">
            <label class="co-field-label">{t.labelStockLength}</label>
            <input type="number" data-co-stock-len data-co-cfg-inp value="2400" class="co-input" />
          </div>
          <div class="co-field co-hidden" data-co-stock-wid-wrap>
            <label class="co-field-label">{t.labelStockWidth}</label>
            <input type="number" data-co-stock-wid data-co-cfg-inp value="1200" class="co-input" />
          </div>
          <div class="co-field">
            <label class="co-field-label">{t.labelKerf}</label>
            <input type="number" data-co-kerf data-co-cfg-inp value="3" class="co-input" />
          </div>
        </div>
      </div>

      <div class="co-card">
        <div class="co-card-title-row">
          <h3 class="co-card-title">
            <Icon name="mdi:format-list-bulleted" />
            {t.cutsTitle}
          </h3>
          <button class="co-btn-add" data-co-btn-add title="+">
            <Icon name="mdi:plus" />
          </button>
        </div>
        <div class="co-cut-list" data-co-list></div>
      </div>
    </div>

    <div class="co-main">
      <div class="co-stats-grid">
        <div class="co-stat-card">
          <div class="co-stat-label">{t.statStockUsed}</div>
          <div class="co-stat-value" data-co-stat-used>0</div>
        </div>
        <div class="co-stat-card">
          <div class="co-stat-label">{t.statTotalCuts}</div>
          <div class="co-stat-value" data-co-stat-cuts>0</div>
        </div>
        <div class="co-stat-card">
          <div class="co-stat-label">{t.statWaste}</div>
          <div class="co-stat-value co-stat-red" data-co-stat-waste>0</div>
        </div>
        <div class="co-stat-card">
          <div class="co-stat-label">{t.statEfficiency}</div>
          <div class="co-stat-value co-stat-green" data-co-stat-eff>0%</div>
        </div>
      </div>

      <div class="co-card co-viz-card">
        <h3 class="co-card-title">
          <Icon name="mdi:eye-outline" />
          {t.vizTitle}
        </h3>
        <div class="co-viz" data-co-viz>
          <div class="co-empty-state" data-co-initial-empty>{t.emptyState}</div>
        </div>
      </div>
    </div>

  </div>

  <template data-co-row-tmpl>
    <div class="co-row">
      <div class="co-row-len-wrap">
        <input type="number" data-co-inp-len placeholder={t.placeholderLength} class="co-row-input" />
        <span class="co-row-unit">mm</span>
      </div>
      <div class="co-row-wid-wrap co-hidden" data-co-wid-wrap>
        <input type="number" data-co-inp-wid placeholder={t.placeholderWidth} class="co-row-input co-row-input-blue" />
        <span class="co-row-unit">mm</span>
      </div>
      <div class="co-row-qty-wrap">
        <input type="number" data-co-inp-qty placeholder={t.placeholderQty} value="1" class="co-row-input co-row-input-qty" />
      </div>
      <button class="co-btn-rm" data-co-btn-rm title={t.btnRemoveTitle}>
        <Icon name="mdi:close" />
      </button>
    </div>
  </template>
</div>

<script>
  import { optimize1D, optimize2D } from './optimizer';
  import type { CutRequest, OptimizationResult, OptimizedPiece, Rect } from './optimizer';

  interface CoState {
    mode: string;
    cuts: CutRequest[];
    calc: () => void;
  }

  interface CoCfg {
    stockLen: number;
    stockWid: number;
    kerf: number;
  }

  function coNum(el: Element | null): number {
    if (!(el instanceof HTMLInputElement)) return 0;
    return parseFloat(el.value) || 0;
  }

  function coAttr(root: Element, key: string): string {
    return root.getAttribute(key) ?? '';
  }

  function coSetText(root: Element, sel: string, text: string): void {
    const el = root.querySelector(sel);
    if (el) el.textContent = text;
  }

  function coDebounce(fn: () => void, ms: number): () => void {
    let timer = 0;
    return () => { clearTimeout(timer); timer = window.setTimeout(fn, ms); };
  }

  function coCfg(root: Element): CoCfg {
    return {
      stockLen: coNum(root.querySelector('[data-co-stock-len]')) || 2400,
      stockWid: coNum(root.querySelector('[data-co-stock-wid]')) || 1200,
      kerf: coNum(root.querySelector('[data-co-kerf]')),
    };
  }

  function coValidCuts(state: CoState): CutRequest[] {
    if (state.mode === 'linear') {
      return state.cuts.filter((c) => c.length > 0 && c.quantity > 0);
    }
    return state.cuts.filter((c) => c.length > 0 && c.width > 0 && c.quantity > 0);
  }

  function coStats1D(root: Element, result: OptimizationResult, stockLen: number): void {
    const totalUsed = result.stockPieces.reduce((a, p) => a + (p.stockLength - p.waste), 0);
    const total = result.totalStockUsed * stockLen;
    const eff = total > 0 ? ((totalUsed / total) * 100).toFixed(1) : '0.0';
    coSetText(root, '[data-co-stat-used]', result.totalStockUsed.toString());
    coSetText(root, '[data-co-stat-cuts]', result.totalCuts.toString());
    coSetText(root, '[data-co-stat-waste]', `${result.totalWaste.toFixed(0)} mm`);
    coSetText(root, '[data-co-stat-eff]', `${eff}%`);
  }

  function coStats2D(root: Element, result: OptimizationResult, cfg: CoCfg): void {
    const totalArea = result.totalStockUsed * cfg.stockLen * cfg.stockWid;
    const usedArea = totalArea - result.totalWaste;
    const eff = totalArea > 0 ? ((usedArea / totalArea) * 100).toFixed(1) : '0.0';
    coSetText(root, '[data-co-stat-used]', result.totalStockUsed.toString());
    coSetText(root, '[data-co-stat-cuts]', result.totalCuts.toString());
    coSetText(root, '[data-co-stat-waste]', `${(result.totalWaste / 1_000_000).toFixed(4)} m²`);
    coSetText(root, '[data-co-stat-eff]', `${eff}%`);
  }

  function coMakeSegment(cutLen: number, stockMax: number): HTMLElement {
    const seg = document.createElement('div');
    seg.className = 'co-seg';
    seg.style.width = `${(cutLen / stockMax) * 100}%`;
    seg.title = `${cutLen}mm`;
    seg.textContent = cutLen < 50 ? '' : `${cutLen}`;
    return seg;
  }

  function coMakeBar1D(root: Element, piece: OptimizedPiece, stockMax: number): HTMLElement {
    const wrap = document.createElement('div');
    wrap.className = 'co-bar-wrap';
    const hdr = document.createElement('div');
    hdr.className = 'co-bar-hdr';
    hdr.innerHTML = `<span>${coAttr(root, 'data-co-stock-label')} #${piece.stockId}</span><span>${coAttr(root, 'data-co-waste-label')} ${piece.waste.toFixed(0)}mm</span>`;
    const bar = document.createElement('div');
    bar.className = 'co-bar';
    (piece.cuts as number[]).forEach((c) => bar.appendChild(coMakeSegment(c, stockMax)));
    wrap.appendChild(hdr);
    wrap.appendChild(bar);
    return wrap;
  }

  function coRender1D(root: Element, pieces: OptimizedPiece[], stockMax: number): void {
    const viz = root.querySelector('[data-co-viz]') as HTMLElement | null;
    if (!viz) return;
    viz.innerHTML = '';
    if (pieces.length === 0) {
      viz.innerHTML = `<div class="co-empty-state">${coAttr(root, 'data-co-no-cuts')}</div>`;
      return;
    }
    pieces.forEach((p) => viz.appendChild(coMakeBar1D(root, p, stockMax)));
  }

  function coMakeRect(rect: Rect, stockLen: number, stockWid: number): HTMLElement {
    const el = document.createElement('div');
    el.className = 'co-rect';
    el.style.left = `${(rect.x / stockLen) * 100}%`;
    el.style.top = `${(rect.y / stockWid) * 100}%`;
    el.style.width = `${(rect.w / stockLen) * 100}%`;
    el.style.height = `${(rect.h / stockWid) * 100}%`;
    el.title = `${rect.w} x ${rect.h}`;
    if (rect.w > 50 && rect.h > 50) el.textContent = `${rect.w}×${rect.h}`;
    return el;
  }

  function coMakePanel2D(root: Element, piece: OptimizedPiece, stockLen: number, stockWid: number): HTMLElement {
    const wrap = document.createElement('div');
    wrap.className = 'co-panel-wrap';
    const hdr = document.createElement('div');
    hdr.className = 'co-bar-hdr';
    hdr.innerHTML = `<span>${coAttr(root, 'data-co-panel-label')} #${piece.stockId}</span><span>${coAttr(root, 'data-co-eff-label')} ${((piece.utilization ?? 0) * 100).toFixed(1)}%</span>`;
    const sheet = document.createElement('div');
    sheet.className = 'co-sheet';
    sheet.style.aspectRatio = `${stockLen}/${stockWid}`;
    (piece.cuts as Rect[]).forEach((r) => sheet.appendChild(coMakeRect(r, stockLen, stockWid)));
    wrap.appendChild(hdr);
    wrap.appendChild(sheet);
    return wrap;
  }

  function coRender2D(root: Element, pieces: OptimizedPiece[], stockLen: number, stockWid: number): void {
    const viz = root.querySelector('[data-co-viz]') as HTMLElement | null;
    if (!viz) return;
    viz.innerHTML = '';
    if (pieces.length === 0) {
      viz.innerHTML = `<div class="co-empty-state">${coAttr(root, 'data-co-no-panels')}</div>`;
      return;
    }
    pieces.forEach((p) => viz.appendChild(coMakePanel2D(root, p, stockLen, stockWid)));
  }

  function coCalc(root: Element, state: CoState): void {
    const cfg = coCfg(root);
    const valid = coValidCuts(state);
    const empty: OptimizationResult = { totalStockUsed: 0, totalWaste: 0, totalCuts: 0, stockPieces: [] };
    if (state.mode === 'linear') {
      const res = valid.length > 0 ? optimize1D(valid, cfg.stockLen, cfg.kerf) : empty;
      coStats1D(root, res, cfg.stockLen);
      coRender1D(root, res.stockPieces, cfg.stockLen);
    } else {
      const res = valid.length > 0 ? optimize2D(valid, cfg.stockLen, cfg.stockWid, cfg.kerf) : empty;
      coStats2D(root, res, cfg);
      coRender2D(root, res.stockPieces, cfg.stockLen, cfg.stockWid);
    }
  }

  function coMakeRow(root: Element, state: CoState, index: number): Element {
    const tmpl = root.querySelector('[data-co-row-tmpl]') as HTMLTemplateElement;
    const clone = tmpl.content.cloneNode(true) as DocumentFragment;
    const row = clone.querySelector('div')!;
    const len = row.querySelector('[data-co-inp-len]') as HTMLInputElement;
    const wid = row.querySelector('[data-co-inp-wid]') as HTMLInputElement;
    const qty = row.querySelector('[data-co-inp-qty]') as HTMLInputElement;
    const widWrap = row.querySelector('[data-co-wid-wrap]') as HTMLElement;
    widWrap?.classList.toggle('co-hidden', state.mode !== 'panel');
    len.value = state.cuts[index].length.toString();
    wid.value = state.cuts[index].width.toString();
    qty.value = state.cuts[index].quantity.toString();
    len.addEventListener('input', () => { state.cuts[index].length = coNum(len); state.calc(); });
    wid.addEventListener('input', () => { state.cuts[index].width = coNum(wid); state.calc(); });
    qty.addEventListener('input', () => { state.cuts[index].quantity = coNum(qty); state.calc(); });
    row.querySelector('[data-co-btn-rm]')?.addEventListener('click', () => {
      state.cuts.splice(index, 1); coRenderRows(root, state); state.calc();
    });
    return row;
  }

  function coRenderRows(root: Element, state: CoState): void {
    const container = root.querySelector('[data-co-list]') as HTMLElement | null;
    if (!container) return;
    container.innerHTML = '';
    state.cuts.forEach((_, i) => container.appendChild(coMakeRow(root, state, i)));
  }

  function coSetMode(root: Element, state: CoState, mode: string): void {
    state.mode = mode;
    root.querySelectorAll('[data-co-mode-btn]').forEach((btn) => {
      btn.classList.toggle('co-mode-active', (btn as HTMLElement).dataset.coModeBtn === mode);
    });
    const widWrap = root.querySelector('[data-co-stock-wid-wrap]') as HTMLElement | null;
    if (widWrap) widWrap.classList.toggle('co-hidden', mode !== 'panel');
    coRenderRows(root, state);
    state.calc();
  }

  function coAttach(root: Element, state: CoState): void {
    root.querySelectorAll('[data-co-mode-btn]').forEach((btn) => {
      btn.addEventListener('click', () => {
        coSetMode(root, state, (btn as HTMLElement).dataset.coModeBtn ?? 'linear');
      });
    });
    root.querySelector('[data-co-btn-add]')?.addEventListener('click', () => {
      state.cuts.push({ id: crypto.randomUUID(), length: 0, width: 0, quantity: 1 });
      coRenderRows(root, state);
    });
    root.querySelectorAll('[data-co-cfg-inp]').forEach((inp) => {
      inp.addEventListener('input', state.calc);
    });
  }

  function coInit(root: Element): void {
    const state: CoState = {
      mode: 'linear',
      cuts: [
        { id: '1', length: 800, width: 400, quantity: 2 },
        { id: '2', length: 450, width: 300, quantity: 3 },
      ],
      calc: () => {},
    };
    state.calc = coDebounce(() => coCalc(root, state), 300);
    coAttach(root, state);
    coSetMode(root, state, 'linear');
    coCalc(root, state);
  }

  document.querySelectorAll('[data-co-root]').forEach(coInit);
</script>

